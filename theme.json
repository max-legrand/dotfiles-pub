  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#FFDCCC"
      }
    },
    {
      "name": "String escapes / interpolation punctuation",
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "Numbers / booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#d6c5a5"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier",
        "storage.type.modifier"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Storage types (var, let, const, function)",
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types / classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "Function / method calls",
      "scope": [
        "meta.function-call",
        "meta.method-call"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "Variables (default identifier color)",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter",
        "meta.definition.variable variable.other"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "Built-in / language variables",
      "scope": [
        "variable.language",
        "variable.other.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties / fields / members",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.property.object",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "meta.brace",
        "meta.bracket"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "Special punctuation (decorators, etc)",
      "scope": [
        "punctuation.decorator",
        "meta.decorator",
        "tag.decorator"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "HTML/JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "HTML/JSX attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "Tag delimiters",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Preprocessor / imports",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Special characters / regex",
      "scope": [
        "constant.character",
        "constant.other.character-class",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "Underlined links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Errors",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ed91b1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ed91b1",
        "fontStyle": "strikethrough"
      }
    },

    "// === Markdown ===",
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#CDC1FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#dddddd",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#dddddd",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code / code blocks",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#FFDCCC"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#00ffaa"
      }
    },
    {
      "name": "Markdown deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ed91b1"
      }
    },
    {
      "name": "Markdown changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#d6c5a5"
      }
    },

    "// === JSON ===",
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.quoted.double.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },

    "// === CSS ===",
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#CDC1FF"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#FFDCCC"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "// Mirror tokenColors but for semantic tokens": "",
    "namespace": "#dddddd",
    "type": {
      "foreground": "#CDC1FF",
      "fontStyle": "italic"
    },
    "class": {
      "foreground": "#CDC1FF",
      "fontStyle": "italic"
    },
    "interface": {
      "foreground": "#CDC1FF",
      "fontStyle": "italic"
    },
    "enum": {
      "foreground": "#CDC1FF",
      "fontStyle": "italic"
    },
    "typeParameter": {
      "foreground": "#CDC1FF",
      "fontStyle": "italic"
    },
    "function": "#CDC1FF",
    "method": "#CDC1FF",
    "macro": "#CDC1FF",
    "variable": "#dddddd",
    "parameter": "#dddddd",
    "property": "#dddddd",
    "enumMember": "#d6c5a5",
    "event": "#CDC1FF",
    "decorator": "#CDC1FF",
    "label": "#CDC1FF",
    "keyword": {
      "foreground": "#CDC1FF",
      "bold": true
    },
    "string": "#FFDCCC",
    "number": "#d6c5a5",
    "comment": {
      "foreground": "#888888",
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.readonly": {
      "foreground": "#888888"
    },
    "*.defaultLibrary": {
      "fontStyle": "italic"
    }
  }
}